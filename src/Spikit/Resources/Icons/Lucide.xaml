<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Iconos Lucide v0.487 portados a Geometry XAML para uso con <Path>.
        ViewBox original: 24x24. Usar Stretch="Uniform" + Width/Height al render.
        Renderizar siempre con Stroke (no Fill) + StrokeThickness=2 + caps Round.

        Fuente original: https://lucide.dev/icons/
        Solo se portan los íconos efectivamente usados en el código actual.
    -->

    <!-- ban: círculo + diagonal cruzando. -->
    <Geometry x:Key="LucideBanGeometry">
        M 12,2 A 10,10 0 1,0 12,22 A 10,10 0 1,0 12,2 Z
        M 4.9,4.9 L 19.1,19.1
    </Geometry>

    <!-- key-round: llave redonda con punto interno. El punto del notch (cx=16.5 cy=7.5 r=.5)
         es prácticamente invisible al render, pero forma parte de la silueta canónica. -->
    <Geometry x:Key="LucideKeyRoundGeometry">
        M 2,18 v3 c 0,0.6 0.4,1 1,1 h 4 v -3 h 3 v -3 h 2 l 1.4,-1.4 a 6.5,6.5 0 1,0 -4,-4 Z
        M 16.5,7 A 0.5,0.5 0 0,1 16.5,8 A 0.5,0.5 0 0,1 16.5,7 Z
    </Geometry>

    <!-- server-crash: dos racks horizontales + dots de status + rayo central. -->
    <Geometry x:Key="LucideServerCrashGeometry">
        M 6,10 H 4 a 2,2 0 0,1 -2,-2 V 4 a 2,2 0 0,1 2,-2 h 16 a 2,2 0 0,1 2,2 v 4 a 2,2 0 0,1 -2,2 h -2
        M 6,14 H 4 a 2,2 0 0,0 -2,2 v 4 a 2,2 0 0,0 2,2 h 16 a 2,2 0 0,0 2,-2 v -4 a 2,2 0 0,0 -2,-2 h -2.343
        M 6,6 h 0.01
        M 6,18 h 0.01
        M 13,6 l -4,6 h 6 l -4,6
    </Geometry>

    <!-- clock: círculo + manecillas (12→12→16,14). -->
    <Geometry x:Key="LucideClockGeometry">
        M 12,2 A 10,10 0 1,0 12,22 A 10,10 0 1,0 12,2 Z
        M 12,6 L 12,12 L 16,14
    </Geometry>

    <!-- text-cursor: I-beam (cursor de texto) compuesto de tres serifs. -->
    <Geometry x:Key="LucideTextCursorGeometry">
        M 17,22 h -1 a 4,4 0 0,1 -4,-4 V 6 a 4,4 0 0,1 4,-4 h 1
        M 7,22 h 1 a 4,4 0 0,0 4,-4 v -1
        M 7,2 h 1 a 4,4 0 0,1 4,4 v 1
    </Geometry>

    <!-- ===== Iconos agregados con EP-11.3 (LoginWindow + AccountWindow) ===== -->

    <!-- mail: sobre con tapa triangular. -->
    <Geometry x:Key="LucideMailGeometry">
        M 4,4 h 16 c 1.1,0 2,0.9 2,2 v 12 c 0,1.1 -0.9,2 -2,2 H 4 c -1.1,0 -2,-0.9 -2,-2 V 6 c 0,-1.1 0.9,-2 2,-2 Z
        M 22,7 L 13.03,13.7 a 2,2 0 0,1 -2.06,0 L 2,7
    </Geometry>

    <!-- log-in: flecha entrando a un panel (entry icon). -->
    <Geometry x:Key="LucideLogInGeometry">
        M 15,3 h 4 a 2,2 0 0,1 2,2 v 14 a 2,2 0 0,1 -2,2 h -4
        M 10,17 l 5,-5 -5,-5
        M 15,12 H 3
    </Geometry>

    <!-- external-link: caja con flecha hacia afuera arriba-derecha. -->
    <Geometry x:Key="LucideExternalLinkGeometry">
        M 15,3 h 6 v 6
        M 10,14 L 21,3
        M 18,13 v 6 a 2,2 0 0,1 -2,2 H 5 a 2,2 0 0,1 -2,-2 V 8 a 2,2 0 0,1 2,-2 h 6
    </Geometry>

    <!-- check-circle: círculo con tilde adentro. -->
    <Geometry x:Key="LucideCheckCircleGeometry">
        M 22,11.08 V 12 a 10,10 0 1,1 -5.93,-9.14
        M 22,4 L 12,14.01 l -3,-3
    </Geometry>

    <!-- x-circle: círculo con cruz adentro. -->
    <Geometry x:Key="LucideXCircleGeometry">
        M 12,2 A 10,10 0 1,0 12,22 A 10,10 0 1,0 12,2 Z
        M 15,9 l -6,6
        M 9,9 l 6,6
    </Geometry>

    <!-- wifi-off: ondas wifi con diagonal cruzando (sin conexión). -->
    <Geometry x:Key="LucideWifiOffGeometry">
        M 12,20 h 0.01
        M 8.5,16.43 a 5,5 0 0,1 7,0
        M 2,8.82 a 15,15 0 0,1 4.17,-2.65
        M 10.66,5 c 4.01,-0.36 8.14,0.9 11.34,3.76
        M 16.85,11.25 a 10,10 0 0,1 2.22,1.68
        M 5,13 a 10,10 0 0,1 5.24,-2.76
        M 2,2 l 20,20
    </Geometry>

    <!-- arrow-left: flecha horizontal a la izquierda. -->
    <Geometry x:Key="LucideArrowLeftGeometry">
        M 19,12 H 5
        M 12,19 l -7,-7 7,-7
    </Geometry>

    <!-- arrow-right: flecha horizontal a la derecha. -->
    <Geometry x:Key="LucideArrowRightGeometry">
        M 5,12 h 14
        M 12,5 l 7,7 -7,7
    </Geometry>

    <!-- rotate-ccw: flecha circular antihoraria (reintentar). -->
    <Geometry x:Key="LucideRotateCcwGeometry">
        M 3,12 a 9,9 0 1,0 9,-9 a 9.75,9.75 0 0,0 -6.74,2.74 L 3,8
        M 3,3 v 5 h 5
    </Geometry>

</ResourceDictionary>
