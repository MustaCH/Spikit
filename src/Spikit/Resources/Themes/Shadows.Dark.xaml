<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DropShadowEffect x:Key="SpkShadowSm"
                      Color="#000000" Opacity="0.4"
                      BlurRadius="2" ShadowDepth="1" Direction="270" />

    <DropShadowEffect x:Key="SpkShadowMd"
                      Color="#000000" Opacity="0.5"
                      BlurRadius="12" ShadowDepth="4" Direction="270" />

    <DropShadowEffect x:Key="SpkShadowLg"
                      Color="#000000" Opacity="0.6"
                      BlurRadius="32" ShadowDepth="12" Direction="270" />

    <!-- Pill: shadow principal. El halo blanco 1px se monta como Border en el componente. -->
    <DropShadowEffect x:Key="SpkShadowPill"
                      Color="#000000" Opacity="0.55"
                      BlurRadius="24" ShadowDepth="8" Direction="270" />

    <!-- Glow rojo del recording dot. ShadowDepth=0 → glow simétrico sin offset. -->
    <DropShadowEffect x:Key="SpkShadowGlowBrand"
                      Color="#FF3B30" Opacity="0.25"
                      BlurRadius="16" ShadowDepth="0" />

</ResourceDictionary>
