<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <SolidColorBrush x:Key="SpkBgCanvasBrush" Color="#0A0A0A" />
    <SolidColorBrush x:Key="SpkBgSurfaceBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="SpkBgElevatedBrush" Color="#242424" />
    <!-- Variantes Mica-aware: alpha 75% (#BF) sobre el color base. Se aplican como
         Window.Background cuando Mica está activa (ver Native/Dwmapi.cs DwmHelper.ApplyBackdrop).
         Alpha 75% deja respirar la Mica como textura de profundidad sin sacrificar legibilidad
         de textos. En Win10/sin Mica actúan sobre el color del padre. -->
    <SolidColorBrush x:Key="SpkBgCanvasMicaBrush" Color="#BF0A0A0A" />
    <SolidColorBrush x:Key="SpkBgSurfaceMicaBrush" Color="#BF1A1A1A" />
    <SolidColorBrush x:Key="SpkBgMutedBrush" Color="#141414" />
    <SolidColorBrush x:Key="SpkBgOverlayBrush" Color="#99000000" />
    <SolidColorBrush x:Key="SpkBgBrandSolidBrush" Color="#FF3B30" />
    <SolidColorBrush x:Key="SpkBgBrandMutedBrush" Color="#1FFF3B30" />

    <!-- Foreground -->
    <SolidColorBrush x:Key="SpkFgPrimaryBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SpkFgSecondaryBrush" Color="#A3A3A3" />
    <SolidColorBrush x:Key="SpkFgMutedBrush" Color="#6B6B6B" />
    <SolidColorBrush x:Key="SpkFgOnBrandBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SpkFgBrandBrush" Color="#FF3B30" />

    <!-- Border -->
    <SolidColorBrush x:Key="SpkBorderDefaultBrush" Color="#262626" />
    <SolidColorBrush x:Key="SpkBorderSubtleBrush" Color="#1F1F1F" />
    <SolidColorBrush x:Key="SpkBorderStrongBrush" Color="#3B3B3B" />
    <SolidColorBrush x:Key="SpkBorderFocusBrush" Color="#FF3B30" />

    <!-- State -->
    <SolidColorBrush x:Key="SpkStateSuccessFgBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="SpkStateSuccessBgBrush" Color="#1F22C55E" />
    <SolidColorBrush x:Key="SpkStateWarningFgBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="SpkStateWarningBgBrush" Color="#1FF59E0B" />
    <SolidColorBrush x:Key="SpkStateErrorFgBrush" Color="#FF3B30" />
    <SolidColorBrush x:Key="SpkStateErrorBgBrush" Color="#1AFF3B30" />
    <SolidColorBrush x:Key="SpkStateInfoFgBrush" Color="#3B82F6" />

    <!-- Color tokens raw (cuando se necesite Color, no Brush) -->
    <Color x:Key="SpkBrandPrimaryColor">#FF3B30</Color>
    <Color x:Key="SpkBrandHoverColor">#FF5C52</Color>
    <Color x:Key="SpkBrandActiveColor">#E62B20</Color>

</ResourceDictionary>
