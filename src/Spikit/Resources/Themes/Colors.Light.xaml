<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <SolidColorBrush x:Key="SpkBgCanvasBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SpkBgSurfaceBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="SpkBgElevatedBrush" Color="#FFFFFF" />
    <!-- Variantes Mica-aware: ver Colors.Dark.xaml. -->
    <SolidColorBrush x:Key="SpkBgCanvasMicaBrush" Color="#BFFFFFFF" />
    <SolidColorBrush x:Key="SpkBgSurfaceMicaBrush" Color="#BFFAFAFA" />
    <SolidColorBrush x:Key="SpkBgMutedBrush" Color="#F4F4F5" />
    <SolidColorBrush x:Key="SpkBgOverlayBrush" Color="#66000000" />
    <SolidColorBrush x:Key="SpkBgBrandSolidBrush" Color="#FF3B30" />
    <SolidColorBrush x:Key="SpkBgBrandMutedBrush" Color="#14FF3B30" />

    <!-- Foreground -->
    <SolidColorBrush x:Key="SpkFgPrimaryBrush" Color="#0A0A0A" />
    <SolidColorBrush x:Key="SpkFgSecondaryBrush" Color="#525252" />
    <SolidColorBrush x:Key="SpkFgMutedBrush" Color="#A3A3A3" />
    <SolidColorBrush x:Key="SpkFgOnBrandBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SpkFgBrandBrush" Color="#E62B20" />

    <!-- Border -->
    <SolidColorBrush x:Key="SpkBorderDefaultBrush" Color="#E4E4E7" />
    <SolidColorBrush x:Key="SpkBorderSubtleBrush" Color="#F4F4F5" />
    <SolidColorBrush x:Key="SpkBorderStrongBrush" Color="#D4D4D8" />
    <SolidColorBrush x:Key="SpkBorderFocusBrush" Color="#FF3B30" />

    <!-- State -->
    <SolidColorBrush x:Key="SpkStateSuccessFgBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="SpkStateSuccessBgBrush" Color="#1A22C55E" />
    <SolidColorBrush x:Key="SpkStateWarningFgBrush" Color="#D97706" />
    <SolidColorBrush x:Key="SpkStateWarningBgBrush" Color="#1FF59E0B" />
    <SolidColorBrush x:Key="SpkStateErrorFgBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="SpkStateErrorBgBrush" Color="#14DC2626" />
    <SolidColorBrush x:Key="SpkStateInfoFgBrush" Color="#2563EB" />

    <!-- Color tokens raw -->
    <Color x:Key="SpkBrandPrimaryColor">#FF3B30</Color>
    <Color x:Key="SpkBrandHoverColor">#FF5C52</Color>
    <Color x:Key="SpkBrandActiveColor">#E62B20</Color>

</ResourceDictionary>
