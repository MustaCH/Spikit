<Window x:Class="Spikit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Spikit"
        Height="520" Width="600"
        Background="{DynamicResource SpkBgCanvasBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Spikit"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="{DynamicResource SpkFgPrimaryBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   FontSize="13"
                   Foreground="{DynamicResource SpkFgSecondaryBrush}"
                   Margin="0,0,0,20"
                   Text="Esta ventana es debug del orchestrator. La pill real llega en la sub-task #6."/>

        <Border Grid.Row="2"
                Background="{DynamicResource SpkBgSurfaceBrush}"
                CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock Text="ESTADO" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource SpkFgSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding PillMessage}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource SpkFgPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="1"
                            Background="{DynamicResource SpkBgElevatedBrush}"
                            CornerRadius="4" Padding="8,4"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding State}"
                                   FontFamily="Consolas, Cascadia Mono, monospace"
                                   FontSize="11"
                                   Foreground="{DynamicResource SpkFgSecondaryBrush}"/>
                    </Border>
                </Grid>
                <TextBlock Margin="0,12,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource SpkFgMutedBrush}"
                           Text="{Binding SessionCount, StringFormat='Sesiones: {0}'}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Margin="0,20,0,8"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource SpkFgSecondaryBrush}"
                   Text="ÚLTIMA TRANSCRIPCIÓN"/>

        <Border Grid.Row="4"
                Background="{DynamicResource SpkBgSurfaceBrush}"
                CornerRadius="8" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding LastTranscription}"
                           FontSize="14"
                           Foreground="{DynamicResource SpkFgPrimaryBrush}"
                           TextWrapping="Wrap"
                           LineHeight="22"/>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="5" Margin="0,12,0,0"
                   FontSize="11"
                   Foreground="{DynamicResource SpkFgMutedBrush}"
                   TextWrapping="Wrap"
                   Text="Para probar paste real: poné foco en otra app antes de apretar Ctrl+Alt+M. Logs en %AppData%\Spikit\logs\."/>
    </Grid>
</Window>
