<UserControl x:Class="Spikit.Views.Settings.Sections.AboutSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <!-- Placeholder de "Sobre la app". Implementación real en EP-4.9
         (versión, links, créditos). -->
    <StackPanel>
        <TextBlock Text="Sobre la app"
                   Style="{StaticResource SpkTypeH1Style}"
                   Margin="0,0,0,12"/>
        <TextBlock Text="Versión, links útiles y créditos."
                   Style="{StaticResource SpkTypeBodyStyle}"
                   Foreground="{DynamicResource SpkFgSecondaryBrush}"
                   Margin="0,0,0,24"/>

        <Border Background="{DynamicResource SpkBgSurfaceBrush}"
                BorderBrush="{DynamicResource SpkBorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
            <StackPanel>
                <TextBlock Text="Pendiente de implementación"
                           Style="{StaticResource SpkTypeBodyStyle}"
                           Foreground="{DynamicResource SpkFgSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Esta sección se completa en EP-4.9."
                           Style="{StaticResource SpkTypeCaptionStyle}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
