<UserControl x:Class="Spikit.Views.Settings.Sections.AboutSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <!-- "Sobre la app" minimalista (EP-4.9). Solo logo + nombre + versión, centrado.
         Sin links / créditos / commit hash — si el usuario quiere más info, accede al
         repo público. -->
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,40,0,40">

            <Image Source="pack://application:,,,/Resources/Brand/logo_rojo.png"
                   Height="48"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />

            <TextBlock Text="{Binding ProductName}"
                       FontFamily="{DynamicResource SpkFontGeist}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SpkFgPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />

            <TextBlock Text="{Binding VersionLabel, StringFormat='v{0}'}"
                       FontFamily="{DynamicResource SpkFontGeistMono}"
                       FontSize="13"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
