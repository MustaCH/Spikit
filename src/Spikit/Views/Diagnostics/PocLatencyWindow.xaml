<Window x:Class="Spikit.Views.Diagnostics.PocLatencyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Spikit — POC latencia (EP-1)"
        Height="380" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SpkBgCanvasBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource SpkTypeH2Style}"
                   Text="POC: latencia de captura de audio" />

        <TextBlock Grid.Row="1"
                   Style="{StaticResource SpkTypeBodyStyle}"
                   Margin="0,8,0,20"
                   Text="Apretá Ctrl+Alt+M para medir." />

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Style="{StaticResource SpkTypeBodyStyle}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="Setup:" />

            <ComboBox x:Name="SetupCombo"
                      Grid.Column="1"
                      SelectedIndex="0"
                      MinWidth="220"
                      HorizontalAlignment="Left">
                <ComboBoxItem Content="laptop-realtek" />
                <ComboBoxItem Content="usb-headset" />
                <ComboBoxItem Content="usb-mic" />
                <ComboBoxItem Content="custom" />
            </ComboBox>

            <Button x:Name="ResetButton"
                    Grid.Column="2"
                    Content="Reset contador"
                    Padding="12,6"
                    Click="ResetButton_Click" />
        </Grid>

        <CheckBox x:Name="ResamplingCheck"
                  Grid.Row="3"
                  IsChecked="True"
                  Margin="0,0,0,16"
                  Foreground="{DynamicResource SpkFgPrimaryBrush}"
                  Content="Resampleo a 16 kHz mono (off = formato nativo del device)" />

        <StackPanel Grid.Row="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock x:Name="CounterText"
                       Style="{StaticResource SpkTypeDisplayStyle}"
                       HorizontalAlignment="Center"
                       Text="0 / 50 mediciones" />
            <TextBlock x:Name="LastLatencyText"
                       Style="{StaticResource SpkTypeMonoStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"
                       Text="Última: —" />
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   Grid.Row="5"
                   Style="{StaticResource SpkTypeCaptionStyle}"
                   Text="Listo." />
    </Grid>
</Window>
