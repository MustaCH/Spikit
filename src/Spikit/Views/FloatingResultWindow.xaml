<Window x:Class="Spikit.Views.FloatingResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spikit — Resultado"
        Width="520" SizeToContent="Height"
        MinHeight="240" MaxHeight="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="False"
        Background="{DynamicResource SpkBgCanvasBrush}">
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.92"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SpkBgElevatedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SpkFgPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SpkBorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SpkBgSurfaceBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Padding="0" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SpkBgSurfaceBrush}"
                    Padding="20,14"
                    BorderBrush="{DynamicResource SpkBorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Spikit · Resultado"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource SpkFgPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseHeaderButton"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,4"
                            Cursor="Hand"
                            Command="{Binding CloseCommand}"
                            Content="✕"
                            FontSize="14"
                            Foreground="{DynamicResource SpkFgSecondaryBrush}"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="24,20,24,0">
                <TextBlock Text="{Binding Heading}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource SpkFgPrimaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{Binding Description}"
                           FontSize="13"
                           Foreground="{DynamicResource SpkFgSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <Border Background="{DynamicResource SpkBgMutedBrush}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource SpkBorderSubtleBrush}"
                        BorderThickness="1"
                        Padding="14,12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240">
                        <TextBox Text="{Binding Text, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas, Cascadia Mono, monospace"
                                 FontSize="13"
                                 Foreground="{DynamicResource SpkFgPrimaryBrush}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="24,20,24,24">
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding CloseCommand}"
                        Content="Cerrar"
                        Margin="0,0,12,0"
                        MinWidth="100"/>
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding CopyCommand}"
                        Content="{Binding CopyButtonLabel}"
                        MinWidth="180"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
