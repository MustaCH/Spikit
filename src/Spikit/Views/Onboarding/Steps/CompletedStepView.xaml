<UserControl x:Class="Spikit.Views.Onboarding.Steps.CompletedStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.RenderTransform>
        <TranslateTransform Y="0"/>
    </UserControl.RenderTransform>
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <!-- Fade-up del bloque entero al volverse visible. Misma duration que los
                     otros steps (320ms) pero con offset Y un poco más generoso para que el
                     "lift" se sienta — es el step de cierre y celebración. -->
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.42"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="24" To="0" Duration="0:0:0.46">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <UserControl.Resources>
        <!-- Switch iOS-style para el opt-in de crash reports (EP-8.3). Duplica el
             SpkSwitchStyle de GeneralSectionView; si EP-6 promueve ese style al Form.xaml
             global, se reemplaza este por DynamicResource. -->
        <Style x:Key="OnboardingSwitchStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="{DynamicResource SpkBgMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SpkBorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Ellipse x:Name="Thumb"
                                         Width="18" Height="18"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="2,0,0,0"
                                         Fill="{DynamicResource SpkFgPrimaryBrush}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource SpkBgBrandSolidBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource SpkBorderStrongBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón primario (pill rojo + scale+glow al hover). El botón vive dentro del
             UserControl porque en este step el footer del Window se oculta. -->
        <Style x:Key="FinishButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="32,14"/>
            <Setter Property="FontFamily" Value="{DynamicResource SpkFontGeist}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="HoverScale" ScaleX="1.0" ScaleY="1.0"/>
                            </Grid.RenderTransform>
                            <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="22"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="BgGlow"
                                                      BlurRadius="16"
                                                      ShadowDepth="0"
                                                      Color="#FF3B30"
                                                      Opacity="0.45"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.04" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.04" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="28" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.7" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.0" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="16" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.45" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="420">

            <!-- Logo Spikit como Image desde el asset oficial — evita romper proporciones
                 al construirlo a mano. Glow rojo de fondo para mantener la identidad
                 visual del brand sin agregar piezas movibles. -->
            <Image Source="pack://application:,,,/Resources/Brand/logo_rojo.png"
                   Width="140" Height="140"
                   Margin="0,0,0,28"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="36"
                                      ShadowDepth="0"
                                      Color="#FF3B30"
                                      Opacity="0.55"/>
                </Image.Effect>
            </Image>

            <TextBlock Text="¡Todo listo!"
                       Style="{StaticResource SpkTypeH1Style}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,28"
                       Text="Apretá tu hotkey desde cualquier app y dictá lo que quieras. Spikit corre en segundo plano."/>

            <!-- Opt-in de crash reports (EP-8.3 / Q-3). Default OFF — el usuario tiene
                 que tildarlo explícitamente. Borde sutil para contener el bloque sin
                 robarle protagonismo al CTA principal. -->
            <Border Background="{DynamicResource SpkBgElevatedBrush}"
                    BorderBrush="{DynamicResource SpkBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14"
                    Margin="0,0,0,28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Enviar crash reports anónimos"
                                   FontFamily="{DynamicResource SpkFontGeist}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource SpkFgPrimaryBrush}"
                                   Margin="0,0,0,2" />
                        <TextBlock FontFamily="{DynamicResource SpkFontGeist}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SpkFgSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Ayudame a debuguear errores. No se incluye audio ni texto transcrito. Lo podés cambiar en Settings → Privacidad cuando quieras." />
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource OnboardingSwitchStyle}"
                              VerticalAlignment="Center"
                              IsChecked="{Binding SendCrashReports, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Button Style="{StaticResource FinishButtonStyle}"
                    Content="Empezar a usar Spikit"
                    Command="{Binding FinishCommand}"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
