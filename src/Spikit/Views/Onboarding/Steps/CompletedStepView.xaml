<UserControl x:Class="Spikit.Views.Onboarding.Steps.CompletedStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.RenderTransform>
        <TranslateTransform Y="0"/>
    </UserControl.RenderTransform>
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <!-- Fade-up del bloque entero al volverse visible. Misma duration que los
                     otros steps (320ms) pero con offset Y un poco más generoso para que el
                     "lift" se sienta — es el step de cierre y celebración. -->
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.42"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="24" To="0" Duration="0:0:0.46">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <UserControl.Resources>
        <!-- Botón primario (pill rojo + scale+glow al hover). El botón vive dentro del
             UserControl porque en este step el footer del Window se oculta. -->
        <Style x:Key="FinishButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="32,14"/>
            <Setter Property="FontFamily" Value="{DynamicResource SpkFontGeist}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="HoverScale" ScaleX="1.0" ScaleY="1.0"/>
                            </Grid.RenderTransform>
                            <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="22"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="BgGlow"
                                                      BlurRadius="16"
                                                      ShadowDepth="0"
                                                      Color="#FF3B30"
                                                      Opacity="0.45"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.04" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.04" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="28" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.7" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.0" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="16" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.45" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="420">

            <!-- Logo Spikit como Image desde el asset oficial — evita romper proporciones
                 al construirlo a mano. Glow rojo de fondo para mantener la identidad
                 visual del brand sin agregar piezas movibles. -->
            <Image Source="pack://application:,,,/Resources/Brand/logo_rojo.png"
                   Width="140" Height="140"
                   Margin="0,0,0,28"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="36"
                                      ShadowDepth="0"
                                      Color="#FF3B30"
                                      Opacity="0.55"/>
                </Image.Effect>
            </Image>

            <TextBlock Text="¡Todo listo!"
                       Style="{StaticResource SpkTypeH1Style}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,32"
                       Text="Apretá tu hotkey desde cualquier app y dictá lo que quieras. Spikit corre en segundo plano."/>

            <Button Style="{StaticResource FinishButtonStyle}"
                    Content="Empezar a usar Spikit"
                    Command="{Binding FinishCommand}"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
