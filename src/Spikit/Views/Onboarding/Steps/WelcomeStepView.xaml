<UserControl x:Class="Spikit.Views.Onboarding.Steps.WelcomeStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <!-- Pantalla 1.0 Welcome — preludio sin stepper. flows.md FLOW 1 + design-system §10.13 / §11.1.
         Tipografía display + lista numerada + CTA primaria centrada (esta última vive en el footer
         del OnboardingWindow).

         EP-11.5 — todo el copy (h1, sub-h, lista, tiempo) es bindable al OnboardingViewModel
         para que el wizard se bifurque por tier sin duplicar UserControls:
           - BYOK         → "Bienvenido a Spikit" + "Tu acceso BYOK es de por vida." + 3 pasos + ~2 min
           - Trial        → "Bienvenido a Spikit" + "Tenés 14 días sin tarjeta, sin trabas." + 2 pasos + ~1 min
           - Pro          → "Gracias por pasarte a Pro 🚀" (sin sub-h) + 2 pasos + ~1 min -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Pulse sutil del logo: respira ligeramente para que la pantalla no quede totalmente estática. -->
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.05"
                             Duration="0:0:2.4">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.05"
                             Duration="0:0:2.4">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Fade-in + slide-up del contenido. -->
                    <DoubleAnimation Storyboard.TargetName="ContentRoot"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.32"/>
                    <DoubleAnimation Storyboard.TargetName="ContentTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="16" To="0"
                                     Duration="0:0:0.32">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LogoPulse}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="ContentRoot"
          MaxWidth="440"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentTranslate" Y="16"/>
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo hero (logo_rojo.png) — design-system §1 dice 80px height para hero del setup wizard.
             Fondo transparente, scale animado para el pulse. -->
        <Image Grid.Row="0"
               Source="pack://application:,,,/Resources/Brand/logo_rojo.png"
               Height="80"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Margin="0,0,0,28"
               RenderOptions.BitmapScalingMode="HighQuality"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <ScaleTransform x:Name="LogoScale" ScaleX="1.0" ScaleY="1.0"/>
            </Image.RenderTransform>
        </Image>

        <!-- H1 — varía por tier: "Bienvenido a Spikit" (BYOK/Trial) | "Gracias por pasarte a Pro 🚀" (Pro). -->
        <TextBlock Grid.Row="1"
                   Text="{Binding WelcomeH1}"
                   Style="{StaticResource SpkTypeDisplayStyle}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,28">
            <!-- Sub-h tier-specific (collapsed en Pro). -->
            <TextBlock Text="{Binding WelcomeTierMessage}"
                       Style="{StaticResource SpkTypeBodyLgStyle}"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       Margin="0,0,0,12"
                       Visibility="{Binding WelcomeTierMessageVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- Intro a la lista — "2 pasos rápidos" o "3 pasos rápidos" según variante. -->
            <TextBlock Text="{Binding WelcomeIntro}"
                       Style="{StaticResource SpkTypeBodyLgStyle}"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <StackPanel HorizontalAlignment="Center">
                <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                           Foreground="{DynamicResource SpkFgPrimaryBrush}"
                           Margin="0,0,0,6">
                    <Run Text="1." FontWeight="SemiBold" Foreground="{DynamicResource SpkFgBrandBrush}"/>
                    <Run Text="  "/>
                    <Run Text="{Binding WelcomeStep1Text}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                           Foreground="{DynamicResource SpkFgPrimaryBrush}"
                           Margin="0,0,0,6">
                    <Run Text="2." FontWeight="SemiBold" Foreground="{DynamicResource SpkFgBrandBrush}"/>
                    <Run Text="  "/>
                    <Run Text="{Binding WelcomeStep2Text}"/>
                </TextBlock>
                <!-- Step 3 solo visible en BYOK. -->
                <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                           Foreground="{DynamicResource SpkFgPrimaryBrush}"
                           Visibility="{Binding WelcomeStep3Visible, Converter={StaticResource BoolToVis}}">
                    <Run Text="3." FontWeight="SemiBold" Foreground="{DynamicResource SpkFgBrandBrush}"/>
                    <Run Text="  "/>
                    <Run Text="{Binding WelcomeStep3Text}"/>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Caption de tiempo — "~2 min" (BYOK) o "~1 minuto" (Trial/Pro). -->
        <TextBlock Grid.Row="3"
                   Text="{Binding WelcomeTimeText}"
                   Style="{StaticResource SpkTypeCaptionStyle}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"/>
    </Grid>
</UserControl>
