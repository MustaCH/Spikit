<UserControl x:Class="Spikit.Views.Onboarding.Steps.PruebaStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.RenderTransform>
        <TranslateTransform Y="0"/>
    </UserControl.RenderTransform>
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.32"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="12" To="0" Duration="0:0:0.32">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <!-- Placeholder — el textbox + flow real de dictado se cablea en EP-3.7 (ticket 86ahb6c5e). -->
    <Grid MaxWidth="480" HorizontalAlignment="Center" VerticalAlignment="Top">
        <StackPanel>
            <TextBlock Text="Probalo"
                       Style="{StaticResource SpkTypeH1Style}"
                       Margin="0,0,0,8"/>
            <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,32"
                       Text="Apretá tu hotkey y dictá una frase corta. Si todo anda, vas a ver el texto acá."/>

            <Border Background="{DynamicResource SpkBgSurfaceBrush}"
                    BorderBrush="{DynamicResource SpkBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    MinHeight="160">
                <StackPanel>
                    <TextBlock Style="{StaticResource SpkTypeBodySmStyle}"
                               Foreground="{DynamicResource SpkFgSecondaryBrush}"
                               Text="PLACEHOLDER · EP-3.7"
                               Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                               Foreground="{DynamicResource SpkFgPrimaryBrush}"
                               TextWrapping="Wrap"
                               Text="Acá va el text box con foco automático y el flow real de dictado integrado al orchestrator. Saltar y Finalizar viven en el footer del Window."/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
