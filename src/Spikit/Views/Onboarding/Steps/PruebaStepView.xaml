<UserControl x:Class="Spikit.Views.Onboarding.Steps.PruebaStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.RenderTransform>
        <TranslateTransform Y="0"/>
    </UserControl.RenderTransform>
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <!-- Misma entrada animada que los otros steps. Además, IsVisibleChanged en
                     code-behind enfoca la TextBox cuando este step se vuelve visible — el
                     foco es crítico porque el dictado real escribe en el control con foco
                     dentro de la window (SendInput Ctrl+V). -->
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.32"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="12" To="0" Duration="0:0:0.32">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <UserControl.Resources>
        <!-- Variante multilínea del SpkTextBox del provider step. Mismo look pero alto fijo,
             padding generoso, scroll vertical, tipografía mono para destacar el texto dictado. -->
        <Style x:Key="DictationTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SpkBgMutedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SpkFgPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource SpkFgPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SpkBorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontFamily" Value="{DynamicResource SpkFontGeist}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Stretch"
                                          BorderThickness="0"
                                          IsTabStop="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SpkBorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SpkBorderFocusBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid MaxWidth="480" HorizontalAlignment="Stretch" VerticalAlignment="Top">
        <StackPanel>
            <TextBlock Text="Probalo"
                       Style="{StaticResource SpkTypeH1Style}"
                       Margin="0,0,0,8"/>
            <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       Text="Apretá tu hotkey y dictá una frase corta. El texto va a aparecer abajo."/>

            <!-- TextBox para la frase de prueba. Alto fijo 200 px. Es prueba corta — no
                 necesita más alto. El binding two-way actualiza HasText cuando el clipboard
                 paste mete el texto transcripto. -->
            <TextBox x:Name="DictationTextBox"
                     Style="{StaticResource DictationTextBoxStyle}"
                     Height="200"
                     Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Hint educativo de latencia (ticket 86aha9uzt): el primer dictado en warm-cold
                 puede tardar ~600ms p50, hasta ~1.5s p99 — sin esta línea el usuario suelta
                 el hotkey o habla antes de tiempo y pierde las primeras sílabas. Versión
                 minimalista debajo del input por decisión de Nacho 2026-05-08 (alternativa
                 al callout descripto en flows.md/design-system.md, que rompía la estética
                 del onboarding). Cierra ADR-0003 §5. -->
            <TextBlock Style="{StaticResource SpkTypeCaptionStyle}"
                       Foreground="{DynamicResource SpkFgMutedBrush}"
                       Margin="2,10,0,0"
                       TextWrapping="Wrap"
                       Text="Tip: esperá a las barras rojas antes de hablar. El primer dictado puede tardar ~1 s."/>
        </StackPanel>
    </Grid>
</UserControl>
