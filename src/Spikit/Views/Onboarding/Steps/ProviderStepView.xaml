<UserControl x:Class="Spikit.Views.Onboarding.Steps.ProviderStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.RenderTransform>
        <TranslateTransform Y="0"/>
    </UserControl.RenderTransform>
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <!-- Cuando el step se vuelve visible, fade-in + slide-up. Animamos el UserControl
                     mismo (Opacity + TranslateY del RenderTransform) — el TargetName no funciona
                     desde Style.Triggers, hay que apuntar al self vía property path. -->
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.32"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="12" To="0" Duration="0:0:0.32">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <!-- Placeholder — la UI real (preset / Base URL / API key / Model / Probar conexión)
         se cablea en EP-3.2 (ticket 86ahb6by4) + EP-3.3 + EP-3.4. -->
    <Grid MaxWidth="480" HorizontalAlignment="Center" VerticalAlignment="Top">
        <StackPanel>
            <TextBlock Text="Conectá tu provider"
                       Style="{StaticResource SpkTypeH1Style}"
                       Margin="0,0,0,8"/>
            <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,32"
                       Text="Cualquier endpoint compatible con la API de OpenAI Whisper. Recomendados: Groq por velocidad, OpenAI por calidad."/>

            <Border Background="{DynamicResource SpkBgSurfaceBrush}"
                    BorderBrush="{DynamicResource SpkBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Style="{StaticResource SpkTypeBodySmStyle}"
                               Foreground="{DynamicResource SpkFgSecondaryBrush}"
                               Text="PLACEHOLDER · EP-3.2 / EP-3.3 / EP-3.4"
                               Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource SpkTypeBodyStyle}"
                               Foreground="{DynamicResource SpkFgPrimaryBrush}"
                               TextWrapping="Wrap"
                               Text="Acá van: dropdown de presets, Base URL, API key (con DPAPI hint), Model y botón Probar conexión con feedback ✓/✗."/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
