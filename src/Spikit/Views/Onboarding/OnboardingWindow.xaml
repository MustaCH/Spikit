<Window x:Class="Spikit.Views.Onboarding.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:steps="clr-namespace:Spikit.Views.Onboarding.Steps"
        mc:Ignorable="d"
        Title="Spikit — Configuración inicial"
        Height="640" Width="560"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource SpkBgCanvasBrush}">

    <!-- Custom chrome: el title bar está adentro del XAML y se renderiza con la marca.
         CaptionHeight=44 hace que los primeros 44px de la window sean draggables (excepto
         elementos hit-testable como el botón ✕). ResizeBorderThickness=0 porque la
         window no es redimensionable (ResizeMode=NoResize). -->
    <!-- GlassFrameThickness="-1": ver justificación en SettingsWindow.xaml. -->
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="-1"
                            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Botones pill-style (radius pill, padding generoso). Comparte filosofía con la
             captura del modal "Cancelar/Borrar" que aprobó Nacho.
             - Primary: solid brand + glow + scale al hover.
             - Secondary: outlined con bg elevado, hover sube a surface.
             - Ghost: sin fondo, color secondary, hover sube foreground a primary. -->
        <Style x:Key="OnbPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,12"/>
            <Setter Property="FontFamily" Value="{DynamicResource SpkFontGeist}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="128"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="HoverScale" ScaleX="1.0" ScaleY="1.0"/>
                            </Grid.RenderTransform>
                            <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="20"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="BgGlow"
                                                      BlurRadius="0"
                                                      ShadowDepth="0"
                                                      Color="#FF3B30"
                                                      Opacity="0"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.03" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.03" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="22" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.7" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.0" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="0" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="BgGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OnbSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SpkBgElevatedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SpkFgPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SpkBorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="28,12"/>
            <Setter Property="FontFamily" Value="{DynamicResource SpkFontGeist}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="128"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SpkBgSurfaceBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource SpkBorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OnbGhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SpkFgSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontFamily" Value="{DynamicResource SpkFontGeist}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SpkFgPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stepper rediseñado: cada círculo tiene su número adentro. Tamaño 28×28 para que
             el dígito se lea cómodo. Sin label "Paso X de Y" al costado — el número ya
             comunica el progreso. -->
        <Style x:Key="StepCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SpkBgMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SpkBorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="StepNumberStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource SpkFontGeist}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SpkFgMutedBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StepLineStyle" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource SpkBorderDefaultBrush}"/>
        </Style>

        <!-- Botón de cerrar la window (✕). WindowChrome.IsHitTestVisibleInChrome=True para que
             reciba clicks aunque esté en la zona de drag del title bar. -->
        <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SpkFgSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <Path x:Name="Glyph"
                                  Data="M 0,0 L 10,10 M 10,0 L 0,10"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SpkBgElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SpkFgPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Border outermost: marco de 1px sutil + corner radius. Da definición a la window
         cuando no hay chrome nativo. CornerRadius requiere AllowsTransparency, que rompe
         DPI awareness — lo dejamos en 0 y compensamos con un border sutil.
         Sin Background propio: el Window.Background del XAML provee el solid de fallback;
         si Mica se aplica en Win11 22H2+, DwmHelper.ApplyBackdrop hace Window.Background=Transparent
         en runtime para destapar el efecto. -->
    <Border BorderBrush="{DynamicResource SpkBorderSubtleBrush}"
            BorderThickness="1">
        <Grid>
            <!-- Fondo del onboarding: imagen planeta-spikit cubriendo toda la window
                 (UniformToFill + centro). La imagen ya trae su propio glow rojo
                 atmosférico (nebulosas + starfield). IsHitTestVisible=False para no
                 robar clicks al content. -->
            <Border IsHitTestVisible="False">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Resources/Brand/planeta-spikit.png"
                                Stretch="UniformToFill"
                                AlignmentX="Center"
                                AlignmentY="Center"/>
                </Border.Background>
            </Border>

            <!-- Overlay negro sutil encima de la imagen para que el copy y los controles
                 tengan más contraste sin perder la atmósfera del fondo. 45% alpha —
                 ajustado post-review con Nacho. -->
            <Border IsHitTestVisible="False"
                    Background="#73000000"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Title bar custom (44px draggable) -->
                    <RowDefinition Height="Auto"/>  <!-- Stepper -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Title bar custom: logo + título a la izquierda, ✕ a la derecha. -->
                <Grid Grid.Row="0" Height="44">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Resources/Brand/logo_rojo.png"
                               Height="18" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Spikit"
                                   FontFamily="{DynamicResource SpkFontGeist}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SpkFgPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <TextBlock Text=" · Configuración inicial"
                                   FontFamily="{DynamicResource SpkFontGeist}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SpkFgSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Click="CloseButton_Click"
                            ToolTip="Cerrar"/>
                </Grid>

                <!-- Stepper con números — visible solo en los 3 pasos numerados. -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,28"
                            Visibility="{Binding IsStepperVisible, Converter={StaticResource BoolToVis}}">

                    <!-- Step 1 (Provider) -->
                    <Grid>
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep1Done}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsStep1Current}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="1">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource StepNumberStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep1Done}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsStep1Current}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Border Margin="8,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StepLineStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLine12Active}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Step 2 (Hotkey) -->
                    <Grid>
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep2Done}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsStep2Current}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource StepNumberStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep2Done}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsStep2Current}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Línea 2→3 + Step 3 — colapsados en Trial/Pro (EP-11.5). El StackPanel
                         re-centra automáticamente cuando los hijos colapsan, no hace falta
                         re-layout manual. -->
                    <Border Margin="8,0"
                            Visibility="{Binding IsLine23Visible, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StepLineStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLine23Active}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Step 3 (Prueba) — visible solo en BYOK. -->
                    <Grid Visibility="{Binding IsStep3Visible, Converter={StaticResource BoolToVis}}">
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep3Current}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SpkBgBrandSolidBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="3">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource StepNumberStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep3Current}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- Content host: padding horizontal, sin top extra (el stepper o el title bar
                     ya respira). Footer en row 3 con su propio padding. -->
                <Grid Grid.Row="2" Margin="28,0,28,0">
                    <steps:WelcomeStepView Visibility="{Binding IsWelcomeStep, Converter={StaticResource BoolToVis}}"/>
                    <steps:ProviderStepView DataContext="{Binding Provider}"
                                            Visibility="{Binding DataContext.IsProviderStep, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <steps:HotkeyStepView DataContext="{Binding Hotkey}"
                                          Visibility="{Binding DataContext.IsHotkeyStep, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <steps:PruebaStepView DataContext="{Binding Prueba}"
                                          Visibility="{Binding DataContext.IsPruebaStep, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <steps:CompletedStepView Visibility="{Binding IsCompletedStep, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Footer. Oculto en el step Completed (su CTA vive dentro del UserControl). -->
                <Grid Grid.Row="3" Margin="28,24,28,24"
                      Visibility="{Binding IsFooterVisible, Converter={StaticResource BoolToVis}}">
                    <!-- Welcome: una sola CTA primaria centrada. -->
                    <Button Style="{StaticResource OnbPrimaryButton}"
                            Command="{Binding GoNextCommand}"
                            Content="{Binding NextButtonLabel}"
                            HorizontalAlignment="Center"
                            MinWidth="200"
                            Visibility="{Binding IsNextCenteredOnly, Converter={StaticResource BoolToVis}}"/>

                    <!-- Steps numerados. -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNextCenteredOnly}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource OnbSecondaryButton}"
                                Command="{Binding GoBackCommand}"
                                HorizontalAlignment="Left"
                                Visibility="{Binding IsBackVisible, Converter={StaticResource BoolToVis}}"
                                Content="← Atrás"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource OnbGhostButton}"
                                    Command="{Binding SkipCommand}"
                                    Content="Saltar"
                                    Margin="0,0,8,0"
                                    Visibility="{Binding IsSkipVisible, Converter={StaticResource BoolToVis}}"/>

                            <Button Style="{StaticResource OnbPrimaryButton}"
                                    Command="{Binding GoNextCommand}"
                                    Content="{Binding NextButtonLabel}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
