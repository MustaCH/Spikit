<Window x:Class="Spikit.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        ShowActivated="False"
        SizeToContent="Height"
        Width="440"
        Title="Spikit Toast"
        UseLayoutRounding="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="ToastBg" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="ToastFg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ToastFgMuted" Color="#A8A8A8"/>
        <SolidColorBrush x:Key="ToastActionFg" Color="#FFFFFF"/>

        <Style TargetType="Button" x:Key="ToastActionButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ToastActionFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Margin = max(BlurRadius, BlurRadius + ShadowDepth) + air. El drop shadow del Border
         (Blur=32, ShadowDepth=8 dirección=270) se extiende ~32px arriba/izq/derecha y
         32+8=40px abajo. Con Margin=40 entra todo sin recortarse. WindowMargin físico al
         workArea es además este valor (lo aplica el host posicionando borde-a-borde). -->
    <Grid x:Name="RootGrid"
          Margin="40"
          Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" X="40"/>
        </Grid.RenderTransform>

        <Border Background="{StaticResource ToastBg}"
                CornerRadius="14"
                MinHeight="44"
                MinWidth="280"
                MaxWidth="360"
                Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32"
                                  ShadowDepth="8"
                                  Direction="270"
                                  Color="Black"
                                  Opacity="0.45"/>
            </Border.Effect>

            <!-- Layout: dot a la izquierda + columna vertical (título → mensaje → acción).
                 Acción abajo-derecha en su propia fila para evitar truncado del label
                 cuando el título es largo y wrappea. -->
            <DockPanel LastChildFill="True">
                <Ellipse DockPanel.Dock="Left"
                         Width="10" Height="10"
                         Fill="{Binding DotBrush}"
                         Margin="0,5,12,0"
                         VerticalAlignment="Top"/>

                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource ToastFg}"
                               FontSize="14"
                               FontWeight="Medium"
                               TextWrapping="Wrap"
                               LineHeight="19"/>
                    <TextBlock Text="{Binding Message}"
                               Visibility="{Binding HasMessage, Converter={StaticResource BoolToVis}}"
                               Foreground="{StaticResource ToastFgMuted}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               LineHeight="16"/>
                    <Button Style="{StaticResource ToastActionButton}"
                            Content="{Binding ActionLabel}"
                            Command="{Binding ActionCommand}"
                            Visibility="{Binding HasAction, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Right"
                            Margin="0,8,-6,-2"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
