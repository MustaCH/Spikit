<Window x:Class="Spikit.Views.DictationPillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Spikit.Views.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        ShowActivated="False"
        Width="220" Height="164"
        Title="Spikit Pill">
    <Window.Resources>
        <SolidColorBrush x:Key="PillBg" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="PillBorderActive" Color="#FF3B30"/>
        <SolidColorBrush x:Key="PillBorderQuiet" Color="#2EFFFFFF"/>
    </Window.Resources>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="140"/>
        </Grid.RenderTransform>

        <!-- Outer wrapper: drop shadow oscura, ofset hacia abajo. -->
        <Border x:Name="DropShadowHost"
                Width="80" Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,70"
                CornerRadius="22"
                Background="{StaticResource PillBg}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="48" ShadowDepth="18"
                                  Direction="270"
                                  Color="Black" Opacity="0.45"/>
            </Border.Effect>

            <!-- Inner: glow rojo centrado (sin offset) + el border visible. -->
            <Border x:Name="PillBorder"
                    CornerRadius="22"
                    Background="{StaticResource PillBg}"
                    BorderBrush="{StaticResource PillBorderQuiet}"
                    BorderThickness="1.5">
                <Border.Effect>
                    <DropShadowEffect x:Name="PillGlow"
                                      BlurRadius="32" ShadowDepth="0"
                                      Color="Black" Opacity="0"/>
                </Border.Effect>
                <controls:LogoWave x:Name="LogoWaveControl"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
            </Border>
        </Border>
    </Grid>
</Window>
