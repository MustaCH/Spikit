<UserControl x:Class="Spikit.Views.Controls.HotkeyCaptureField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Focusable="True"
             FocusVisualStyle="{x:Null}"
             Background="Transparent"
             KeyboardNavigation.IsTabStop="True"
             d:DesignHeight="36" d:DesignWidth="320">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Botón "🖉" inline a la derecha. Look minimalista alineado al EyeToggleStyle
             del ProviderStepView para mantener coherencia visual entre los inputs del
             onboarding. -->
        <Style x:Key="EditToggleStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SpkFgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ToolTip" Value="Cambiar combinación"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SpkBgElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SpkFgPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="OuterBorder"
            Background="{DynamicResource SpkBgMutedBrush}"
            BorderBrush="{DynamicResource SpkBorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Height="36"
            Padding="12,0"
            SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <!-- Hover sutil: solo cambia border, no bg, para que no compita con
                         la transición a Capturing. -->
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SpkBorderStrongBrush}"/>
                    </DataTrigger>
                    <!-- Capturing: borde focus (2px brand) + bg ligero para indicar "estoy
                         escuchando teclas". design-system §10.3 (Capturing state). -->
                    <DataTrigger Binding="{Binding IsCapturing, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SpkBorderFocusBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Texto del centro: muestra la combinación capturada (mono-kbd) o el
                 placeholder de captura. Visibilidades mutuamente excluyentes vía bools del code-behind. -->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding HotkeyDisplay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontFamily="{DynamicResource SpkFontGeistMono}"
                       FontSize="13"
                       FontWeight="Medium"
                       Foreground="{DynamicResource SpkFgPrimaryBrush}"
                       Visibility="{Binding ShowHotkey, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Apretá tu combinación…"
                       FontFamily="{DynamicResource SpkFontGeist}"
                       FontSize="14"
                       Foreground="{DynamicResource SpkFgSecondaryBrush}"
                       Visibility="{Binding IsCapturing, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Click para capturar"
                       FontFamily="{DynamicResource SpkFontGeist}"
                       FontSize="14"
                       Foreground="{DynamicResource SpkFgMutedBrush}"
                       Visibility="{Binding ShowEmptyPlaceholder, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

            <!-- Edit button: visible solo cuando hay hotkey + no estamos capturando. Volver
                 a apretar pone el control en Capturing. -->
            <Button Grid.Column="1"
                    x:Name="EditButton"
                    Style="{StaticResource EditToggleStyle}"
                    Content="🖉"
                    Click="EditButton_Click"
                    Visibility="{Binding ShowEditButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Border>
</UserControl>
