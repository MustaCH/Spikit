<Window x:Class="Spikit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Spikit"
        mc:Ignorable="d"
        Title="Spikit — fonts smoke test"
        Height="320" Width="560"
        Background="#0A0A0A">
    <StackPanel Margin="32" VerticalAlignment="Center">
        <TextBlock Text="Spikit"
                   FontFamily="pack://application:,,,/Resources/Fonts/#Geist"
                   FontSize="48"
                   FontWeight="SemiBold"
                   Foreground="#FFFFFF" />
        <TextBlock Text="No lo escribas. Spikit"
                   FontFamily="pack://application:,,,/Resources/Fonts/#Geist"
                   FontSize="16"
                   FontWeight="Normal"
                   Foreground="#A3A3A3"
                   Margin="0,4,0,24" />
        <TextBlock Text="Ctrl + Alt + Space"
                   FontFamily="pack://application:,,,/Resources/Fonts/#Geist Mono"
                   FontSize="14"
                   FontWeight="Medium"
                   Foreground="#FF3B30" />
    </StackPanel>
</Window>
