<Window x:Class="Spikit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Spikit"
        mc:Ignorable="d"
        Title="Spikit — tokens smoke test"
        Height="320" Width="560"
        Background="{DynamicResource SpkBgCanvasBrush}">
    <StackPanel Margin="32" VerticalAlignment="Center">
        <TextBlock Text="Spikit"
                   Style="{StaticResource SpkTypeDisplayStyle}" />
        <TextBlock Text="No lo escribas. Spikit"
                   Style="{StaticResource SpkTypeBodyLgStyle}"
                   Foreground="{DynamicResource SpkFgSecondaryBrush}"
                   Margin="0,4,0,24" />
        <TextBlock Text="Ctrl + Alt + Space"
                   Style="{StaticResource SpkTypeMonoKbdStyle}"
                   Foreground="{DynamicResource SpkFgBrandBrush}" />
    </StackPanel>
</Window>
